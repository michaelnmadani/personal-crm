{
  "name": "personal-crm",
  "private": true,
  "version": "0.1.0",
  "description": "Personal CRM — contacts, meeting notes, reminders, and a relationship network graph.",
  "author": "michaelnmadani",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "icons": "node scripts/make-icons.mjs",
    "electron:dev": "concurrently -k \"vite\" \"wait-on tcp:127.0.0.1:5173 && cross-env ELECTRON_DEV=1 electron electron/main.cjs\"",
    "electron:build": "node scripts/make-icons.mjs && cross-env ELECTRON=true tsc -b && cross-env ELECTRON=true vite build",
    "electron:pack": "npm run electron:build && electron-builder --dir",
    "electron:dist": "npm run electron:build && electron-builder",
    "electron:release": "npm run electron:build && electron-builder --publish always"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.0",
    "@tanstack/react-query": "^5.66.0",
    "cytoscape": "^3.34.0",
    "date-fns": "^4.1.0",
    "electron-updater": "^6.3.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/cytoscape": "^3.21.9",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.3",
    "vite": "^6.0.0",
    "vite-plugin-pwa": "^0.21.1",
    "wait-on": "^8.0.1"
  }
}
